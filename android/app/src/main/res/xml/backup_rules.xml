<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude sensitive data from Android Auto Backup -->

    <!-- Exclude Keychain/Keystore data -->
    <exclude domain="sharedpref" path="RNKeychainManager_PREFS.xml" />

    <!-- Exclude secure storage preferences -->
    <exclude domain="sharedpref" path="secure_storage.xml" />

    <!-- Exclude AsyncStorage which may contain tokens -->
    <exclude domain="database" path="RKStorage" />

    <!-- Exclude cache directory -->
    <exclude domain="file" path="cache/" />
</full-backup-content>
